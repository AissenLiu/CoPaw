{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CoPaw Desktop",
  "version": "0.1.0",
  "identifier": "io.agentscope.copaw.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CoPaw Desktop",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false
  }
}
